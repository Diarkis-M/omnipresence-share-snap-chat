# Claude API — Haiku for relevance gate + scoring
ANTHROPIC_API_KEY=

# Google Custom Search (primary discovery channel)
# Free tier: 100 queries/day
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ShareChat API (optional — undocumented, requires free user account)
# Create a free account at sharechat.com, then extract credentials from browser Network tab
# Open DevTools → Network → look for requests to apis.sharechat.com or restapi1.sharechat.com
# Extract the userId and passCode from request payloads
SHARECHAT_USER_ID=
SHARECHAT_PASSCODE=
