# ═══════════════════════════════════════════════════════
# Muuchstac Scout — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your keys:
#   cp .env.example .env.local
#
# NEVER commit .env.local — it is gitignored by default.
# ═══════════════════════════════════════════════════════

# YouTube Data API v3 key
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your GCP project
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic Claude API key
# Get one at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=sk-ant-your_key_here

# Apify API token (for Instagram Reels analysis)
# Get one at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your_token_here
